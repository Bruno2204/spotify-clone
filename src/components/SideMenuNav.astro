---
import Home from '../icons/Home.astro';
import Search from '../icons/Search.astro';
const NAVS = [
  { href: '/', label: 'Home', icon: Home },
  { href: '#', label: 'Search', icon: Search },
];
---

<nav
  class='bg-section-bg text-zinc-400 font-semibold rounded-lg m-2 p-4 flex flex-col gap-5 justify-center'
>
  {
    NAVS.map((nav) => (
      <a
        href={nav.href}
        class='hover:text-zinc-100 transition-colors duration-300 ease-in-out  flex items-center gap-4'
      >
        <nav.icon />
        {nav.label}
      </a>
    ))
  }
</nav>
