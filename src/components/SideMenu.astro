---
import Library from '../icons/Library.astro';
import SideMenuNav from './SideMenuNav.astro';
import SideMenuCard from './SideMenuCard.astro';

import { playlists, type Playlist } from '@/lib/data.js';
---

<SideMenuNav />
<section
  class='bg-section-bg text-zinc-400 font-semibold rounded-lg m-2 p-4 flex-1 flex flex-col gap-4'
>
  <span class='flex flex-row gap-4'>
    <Library />
    Library
  </span>
  <div class='flex flex-col gap-4'>
    {
      playlists.map((playlist: Playlist) => (
        <SideMenuCard playlist={playlist} />
      ))
    }
  </div>
</section>
