---
import type { Playlist } from '@/lib/data.js';
interface Props {
  playlist: Playlist;
}

const { playlist } = Astro.props;
const { id, title, color, cover, artists } = playlist;

const artistsString: string = artists.join(', ');
---

<a
  href={`/playlist/${id}`}
  class='flex flex-col gap-3 hover:bg-zinc-800 rounded-lg transition-colors duration-300 ease-in-out z-10 bg-white/20 backdrop-blur-sm w-42 p-3'
>
  <picture class='aspect-square w-full h-auto'>
    <img src={cover} alt={title} class='rounded' />
  </picture>
  <div class='flex flex-col gap-1'>
    <h3 class='text-white text-md font-normal truncate'>{title}</h3>
    <p class='text-zinc-400 text-sm font-normal truncate'>{artistsString}</p>
  </div>
</a>
