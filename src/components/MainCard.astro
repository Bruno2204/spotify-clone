---
import type { Playlist } from '@/lib/data.js';
import { CardPlayButton } from './CardPlayButton.jsx';
interface Props {
  playlist: Playlist;
}

const { playlist } = Astro.props;
const { id, title, color, cover, artists } = playlist;

const artistsString: string = artists.join(', ');
---

<article class='group relative'>
  <CardPlayButton id={id} />
  <a
    href={`/playlist/${id}`}
    class='flex flex-col gap-3 flex-1 h-full group-hover:bg-zinc-800 rounded-lg transition-colors duration-300 ease-in-out z-10 bg-white/20 backdrop-blur-sm w-36 p-3'
    transition:name=`playlist-${id}-box`
  >
    <picture class='aspect-square w-full h-auto'>
      <img
        src={cover}
        alt={title}
        class='rounded-md'
        transition:name=`playlist-${id}-image`
      />
    </picture>
    <div class='flex flex-col gap-1'>
      <h3
        class='text-white text-md font-normal truncate'
        transition:name=`playlist-${id}-title`
      >
        {title}
      </h3>
      <p
        class='text-zinc-400 text-sm font-normal line-clamp-2'
        transition:name=`playlist-${id}-artists`
      >
        {artistsString}
      </p>
    </div>
  </a>
</article>
