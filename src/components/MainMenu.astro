---
import { playlists } from '@/lib/data.js';
import MainCard from './MainCard.astro';
import Greeting from './Greeting.astro';
---

<div
  id='playlist-container'
  class='relative transition-all duration-1000 bg-section-bg m-2 rounded-lg z-10 w-full'
>
  <div class='relative z-20 m-3 mt-6'>
    <Greeting />
    <div class='flex flex-wrap z-10 gap-x-4 gap-y-6 mt-2'>
      {playlists.map((playlist) => <MainCard playlist={playlist} />)}
    </div>
  </div>
  <div
    class='absolute inset-0 bg-linear-to-b from-green-500 via-green-700/30 to-section-bg/80 rounded-lg h-[40%] -z-10'
  >
  </div>
</div>
